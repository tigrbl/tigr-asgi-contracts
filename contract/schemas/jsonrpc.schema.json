{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "jsonrpc.schema.json",
  "$defs": {
    "id": {
      "type": [
        "string",
        "number",
        "null"
      ]
    },
    "request": {
      "type": "object",
      "required": [
        "jsonrpc",
        "method"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "method": {
          "type": "string"
        },
        "params": {
          "type": [
            "array",
            "object"
          ]
        },
        "id": {
          "$ref": "#/$defs/id"
        }
      },
      "additionalProperties": false
    },
    "notification": {
      "type": "object",
      "required": [
        "jsonrpc",
        "method"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "method": {
          "type": "string"
        },
        "params": {
          "type": [
            "array",
            "object"
          ]
        }
      },
      "not": {
        "required": [
          "id"
        ]
      },
      "additionalProperties": false
    },
    "error": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string"
        },
        "data": true
      },
      "additionalProperties": false
    },
    "successResponse": {
      "type": "object",
      "required": [
        "jsonrpc",
        "result",
        "id"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "result": true,
        "id": {
          "$ref": "#/$defs/id"
        }
      },
      "additionalProperties": false
    },
    "errorResponse": {
      "type": "object",
      "required": [
        "jsonrpc",
        "error",
        "id"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "error": {
          "$ref": "#/$defs/error"
        },
        "id": {
          "$ref": "#/$defs/id"
        }
      },
      "additionalProperties": false
    },
    "batch": {
      "type": "array",
      "minItems": 1,
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/request"
          },
          {
            "$ref": "#/$defs/notification"
          }
        ]
      }
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/request"
    },
    {
      "$ref": "#/$defs/notification"
    },
    {
      "$ref": "#/$defs/successResponse"
    },
    {
      "$ref": "#/$defs/errorResponse"
    },
    {
      "$ref": "#/$defs/batch"
    }
  ]
}
