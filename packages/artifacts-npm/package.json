{
  "name": "@tigr/contract-artifacts",
  "version": "0.1.1",
  "type": "module",
  "files": [
    "contract/**",
    "index.js",
    "README.md",
    "scripts/**"
  ],
  "exports": {
    ".": "./index.js",
