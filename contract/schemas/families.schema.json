{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tigr.dev/asgi-contract/schemas/families.schema.json",
  "title": "Family vocabulary",
  "type": "object",
  "required": ["families"],
  "properties": {
    "families": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["request", "session", "message", "stream", "datagram", "lifespan"]
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
