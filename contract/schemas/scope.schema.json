    "asgi": {
      "type": "object"
    },
    "scheme": {
      "type": "string"
    },
    "http_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "method": {
      "type": [
        "string",
        "null"
      ]
    },
    "path": {
      "type": "string"
    },
    "query_string": {
      "type": "string",
      "contentEncoding": "base64"
    },
    "headers": {
      "type": "array",
      "items": {
        "type": "array",
        "prefixItems": [
