            {
              "type": "string"
            },
            {
              "type": "integer"
            }
          ],
          "items": false
        }
      ]
    },
    "server": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "array",
          "prefixItems": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            }
          ],
          "items": false
        }
      ]
    },
