{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "event.schema.json",
  "type": "object",
  "required": [
    "type"
  ],
  "properties": {
    "type": {
      "enum": [
        "http.request",
        "http.disconnect",
        "http.response.start",
        "http.response.body",
        "http.response.pathsend",
        "websocket.connect",
        "websocket.receive",
        "websocket.disconnect",
        "websocket.accept",
        "websocket.send",
        "websocket.close",
        "webtransport.connect",
        "webtransport.accept",
        "webtransport.stream.receive",
        "webtransport.stream.send",
        "webtransport.stream.close",
        "webtransport.stream.reset",
        "webtransport.stream.stop_sending",
        "webtransport.datagram.receive",
        "webtransport.datagram.send",
        "webtransport.disconnect",
        "webtransport.close",
        "lifespan.startup",
        "lifespan.startup.complete",
        "lifespan.startup.failed",
        "lifespan.shutdown",
        "lifespan.shutdown.complete",
        "lifespan.shutdown.failed",
        "transport.emit.complete",
        "transport.emit.failed"
      ]
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "payload": {
      "type": "object",
      "default": {}
    }
  },
  "additionalProperties": false
}
